{
  "name": "asknatural-shopify-theme",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "dev:assets": "vite build",
    "encode:hero": "node scripts/encode-hero-video.mjs",
    "build": "vite build",
    "prestart": "npm run dev:assets",
    "shopify:dev": "shopify theme dev -s ask-naturals.myshopify.com",
    "shopify:info": "shopify theme info -s ask-naturals.myshopify.com",
    "theme:dev": "shopify theme dev -s ask-naturals.myshopify.com",
    "deploy:assets": "npm run build && shopify theme push -s ask-naturals.myshopify.com --only assets/ --only layout/theme.liquid",
    "start": "concurrently -n vite,shopify -c blue,green \"npm run dev\" \"npm run shopify:dev\""
  },
  "dependencies": {
    "@shopify/storefront-api-client": "^1.0.3",
    "gsap": "^3.15.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}