{% doc %}
  Full product payload for ProductDetail React section (variants, images, description).

  @param {product} product - Shopify product object
{% enddoc %}

{%- liquid
  assign detail_variant = nil
  for variant in product.variants
    if variant.available
      assign detail_variant = variant
      break
    endif
  endfor
  if detail_variant == nil
    assign detail_variant = product.selected_or_first_available_variant
  endif
-%}

{%- capture variants_json -%}
[
{%- for variant in product.variants -%}
  {
    "id": {{ variant.id | json }},
    "title": {{ variant.title | json }},
    "price": {{ variant.price | json }},
    "compare_at_price": {{ variant.compare_at_price | json }},
    "available": {{ variant.available | json }}
  }{%- unless forloop.last -%},{%- endunless -%}
{%- endfor -%}
]
{%- endcapture -%}

{%- capture images_json -%}
[
{%- if product.images.size > 0 -%}
  {%- for image in product.images -%}
    {{ image | image_url: width: 1200 | json }}{%- unless forloop.last -%},{%- endunless -%}
  {%- endfor -%}
{%- elsif product.featured_image -%}
  {{ product.featured_image | image_url: width: 1200 | json }}
{%- endif -%}
]
{%- endcapture -%}

{
  "id": {{ product.id | json }},
  "title": {{ product.title | json }},
  "handle": {{ product.handle | json }},
  "url": {{ product.url | json }},
  "vendor": {{ product.vendor | json }},
  "description": {{ product.description | json }},
  "featured_image": {% if product.featured_image %}{{ product.featured_image | image_url: width: 1200 | json }}{% else %}null{% endif %},
  "images": {{ images_json }},
  "variants": {{ variants_json }},
  "available": {{ product.available | json }}
}
