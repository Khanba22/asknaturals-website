{%- capture stats_json -%}
[
{%- for block in section.blocks -%}
  {
    "value": {{ block.settings.value | json }},
    "label": {{ block.settings.label | json }}
  }{%- unless forloop.last -%},{%- endunless -%}
{%- endfor -%}
]
{%- endcapture -%}

{%- capture config_json -%}
{
  "heading": {{ section.settings.heading | json }},
  "description": {{ section.settings.description | json }},
  "stats": {{ stats_json }}
}
{%- endcapture -%}

{% render 'react-mount',
  mount_id: 'stats-' | append: section.id,
  component: 'Stats',
  config_json: config_json,
  shopify_attributes: section.shopify_attributes
%}

{% schema %}
{
  "name": "Stats",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "WELLNESS SUPPORT DESIGNED AROUND REAL WOMEN"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "We believe wellness should feel personal, not overwhelming. Our approach is rooted in science, guided by care, and designed to fit naturally into everyday life."
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        { "type": "text", "id": "value", "label": "Value", "default": "12,000+" },
        { "type": "text", "id": "label", "label": "Label", "default": "Wellness routines supported" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Stats",
      "blocks": [
        { "type": "stat", "settings": { "value": "12,000+", "label": "Wellness routines supported" } },
        { "type": "stat", "settings": { "value": "5+", "label": "Years of research" } },
        { "type": "stat", "settings": { "value": "1,800+", "label": "Coaching hours" } },
        { "type": "stat", "settings": { "value": "94%", "label": "Community trust" } },
      ]
    }
  ]
}
{% endschema %}
