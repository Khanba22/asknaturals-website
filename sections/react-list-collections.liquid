{%- capture collections_json -%}
[
{%- for collection in collections -%}
  {
    "id": {{ collection.id | json }},
    "title": {{ collection.title | json }},
    "handle": {{ collection.handle | json }},
    "url": {{ collection.url | json }},
    "description": {{ collection.description | strip_html | truncate: 160 | json }},
    "image_url": {% if collection.featured_image %}{{ collection.featured_image | image_url: width: 800 | json }}{% else %}null{% endif %},
    "products_count": {{ collection.products_count | json }}
  }{%- unless forloop.last -%},{%- endunless -%}
{%- endfor -%}
]
{%- endcapture -%}

{%- capture config_json -%}
{
  "heading": {{ section.settings.heading | json }},
  "subtext": {{ section.settings.subtext | json }},
  "collections": {{ collections_json }}
}
{%- endcapture -%}

{% render 'react-mount',
  mount_id: 'list-collections',
  component: 'ListCollections',
  config_json: config_json,
  shopify_attributes: section.shopify_attributes
%}

{% schema %}
{
  "name": "Collections list",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Collections" },
    { "type": "text", "id": "subtext", "label": "Subtext", "default": "Browse our product collections" }
  ]
}
{% endschema %}
