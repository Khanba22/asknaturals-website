{%- if customer -%}
  {% render 'customer-auth-redirect', redirect_url: routes.account_url %}
{%- else -%}
  {% render 'customer-auth-redirect', redirect_url: routes.storefront_login_url %}
{%- endif -%}

{% schema %}
{
  "name": "Customer register",
  "tag": "section",
  "class": "section",
  "enabled_on": {
    "templates": ["customers/register"]
  },
  "settings": [
    {
      "type": "paragraph",
      "content": "New customer accounts use the same email sign-in flow for registration. Redirects immediately."
    }
  ],
  "presets": [
    {
      "name": "Customer register"
    }
  ]
}
{% endschema %}
