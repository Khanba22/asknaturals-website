{%- capture config_json -%}
{
  "heading": {{ section.settings.heading | json }},
  "subtext": {{ section.settings.subtext | json }},
  "form_errors": {% render 'customer-form-errors' %},
  "form_type": {{ form.type | json }}
}
{%- endcapture -%}

{% render 'react-mount',
  mount_id: 'customer-reset-password',
  component: 'CustomerResetPassword',
  config_json: config_json,
  shopify_attributes: section.shopify_attributes
%}

{% schema %}
{
  "name": "Customer reset password",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Reset password" },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Enter a new password for your account."
    }
  ]
}
{% endschema %}
