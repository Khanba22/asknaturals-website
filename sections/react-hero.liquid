{%- liquid
  assign overlay_header = false
  if template.name == 'index'
    assign overlay_header = true
  endif

  assign desktop_video_url = 'desktop_animation.mp4' | asset_url
  assign mobile_video_url = 'mobile_animation.mp4' | asset_url

  if section.settings.desktop_video != blank
    for source in section.settings.desktop_video.sources
      if source.mime_type contains 'mp4' or source.format == 'mp4'
        assign desktop_video_url = source.url
        break
      endif
    endfor
    if desktop_video_url == blank and section.settings.desktop_video.sources.size > 0
      assign desktop_video_url = section.settings.desktop_video.sources.first.url
    endif
  endif

  if section.settings.mobile_video != blank
    for source in section.settings.mobile_video.sources
      if source.mime_type contains 'mp4' or source.format == 'mp4'
        assign mobile_video_url = source.url
        break
      endif
    endfor
    if mobile_video_url == blank and section.settings.mobile_video.sources.size > 0
      assign mobile_video_url = section.settings.mobile_video.sources.first.url
    endif
  endif
-%}
{%- capture config_json -%}
{
  "subtitle": {{ section.settings.subtitle | json }},
  "heading": {{ section.settings.heading | json }},
  "description": {{ section.settings.description | json }},
  "button_label": {{ section.settings.button_label | json }},
  "button_link": {{ section.settings.button_link | json }},
  "button_label_2": {{ section.settings.button_label_2 | json }},
  "button_link_2": {{ section.settings.button_link_2 | json }},
  "overlay_header": {{ overlay_header | json }},
  "show_trust_badges": {{ section.settings.show_trust_badges | json }},
  "show_floating_badges": {{ section.settings.show_floating_badges | json }},
  "color_scheme": {{ section.settings.color_scheme | json }},
  "scroll_distance": {{ section.settings.scroll_distance | json }},
  "intro_autoplay": {{ section.settings.intro_autoplay | json }},
  "desktop_video_url": {{ desktop_video_url | json }},
  "mobile_video_url": {{ mobile_video_url | json }}
}
{%- endcapture -%}

{% render 'react-mount',
  mount_id: 'hero-' | append: section.id,
  component: 'Hero',
  config_json: config_json,
  shopify_attributes: section.shopify_attributes
%}

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "PREMIUM SUPPLEMENTS"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>SUPPLEMENTS DESIGNED AROUND HER BIOLOGY.</p>"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Clinically selected ingredients to support hormones, digestion, metabolism and energy.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Second button label"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Second button link"
    },
    {
      "type": "range",
      "id": "scroll_distance",
      "label": "Scroll distance",
      "info": "Viewport heights for the full hero sequence. 1vh keeps the Shop Now button in view without scrolling past the section.",
      "min": 1,
      "max": 6,
      "step": 0.5,
      "unit": "vh",
      "default": 1.5
    },
    {
      "type": "checkbox",
      "id": "intro_autoplay",
      "label": "Auto-scroll intro on load",
      "default": true
    },
    {
      "type": "video",
      "id": "desktop_video",
      "label": "Desktop scroll video",
      "info": "Optional. Overrides theme asset desktop_animation.mp4."
    },
    {
      "type": "video",
      "id": "mobile_video",
      "label": "Mobile scroll video",
      "info": "Optional. Overrides theme asset mobile_animation.mp4."
    },
    {
      "type": "checkbox",
      "id": "show_trust_badges",
      "label": "Show trust badges",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_floating_badges",
      "label": "Show floating badges",
      "default": true
    },
    {
      "type": "text",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
