{%- if customer -%}
  {% render 'customer-auth-redirect', redirect_url: routes.account_url %}
{%- else -%}
  {% render 'customer-auth-redirect', redirect_url: routes.storefront_login_url %}
{%- endif -%}

{% schema %}
{
  "name": "Customer login",
  "tag": "section",
  "class": "section",
  "enabled_on": {
    "templates": ["customers/login"]
  },
  "settings": [
    {
      "type": "paragraph",
      "content": "Redirects immediately to Shopify email sign-in. Customize sign-in branding in Settings → Customer accounts."
    }
  ],
  "presets": [
    {
      "name": "Customer login"
    }
  ]
}
{% endschema %}
