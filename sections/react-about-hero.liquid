{%- capture config_json -%}
{
  "eyebrow": {{ section.settings.eyebrow | json }},
  "heading": {{ section.settings.heading | json }},
  "body": {{ section.settings.body | json }},
  "image_url": {% if section.settings.image != blank %}{{ section.settings.image | image_url: width: 1600 | json }}{% else %}null{% endif %}
}
{%- endcapture -%}

{% render 'react-mount',
  mount_id: 'about-hero-' | append: section.id,
  component: 'AboutHero',
  config_json: config_json,
  shopify_attributes: section.shopify_attributes
%}

{% schema %}
{
  "name": "About hero",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "About Askknatural" },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Wellness Inspired By Nature. Backed By Science."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "info": "Separate paragraphs with a blank line.",
      "default": "At Askknatural, we believe that good health begins with the choices we make every day.\n\nIn a world filled with complicated health advice and unrealistic promises, our goal is simple: create products that make healthy living easier, more enjoyable, and more sustainable.\n\nOur brand was born from the belief that wellness should be accessible, practical, and rooted in both nature and science. Every product we develop is inspired by this philosophy—combining thoughtfully selected ingredients with evidence-based formulations to support modern health needs."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image",
      "info": "Displayed as a full-section background, anchored to the center right."
    }
  ],
  "presets": [{ "name": "About hero" }]
}
{% endschema %}
