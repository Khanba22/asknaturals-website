{%- capture contact_items_json -%}[{%- render 'contact-items-json', section: section -%}]{%- endcapture -%}

{% form 'contact', id: 'ContactForm', class: 'hidden' %}
{% endform %}

{%- capture config_json -%}
{"heading":{{ section.settings.heading | json }},"breadcrumbs":[{"title":"Home","url":{{ routes.root_url | json }}},{"title":{{ page.title | default: 'Contact us' | json }},"url":{{ request.path | json }}}],"intro_heading":{{ section.settings.intro_heading | json }},"intro_text":{{ section.settings.intro_text | json }},"form_heading":{{ section.settings.form_heading | json }},"form_text":{{ section.settings.form_text | json }},"form_id":"ContactForm","form_posted_successfully":{{ form.posted_successfully? | json }},"form_errors":{% render 'customer-form-errors' %},"form_name":{{ form.name | json }},"form_email":{{ form.email | json }},"form_phone":{{ form.phone | json }},"form_body":{{ form.body | json }},"phone_default_country":{{ section.settings.phone_default_country | json }},"contact_items":{{ contact_items_json }}}
{%- endcapture -%}

{% render 'react-mount',
  mount_id: 'contact-page-' | append: section.id,
  component: 'ContactPage',
  config_json: config_json,
  shopify_attributes: section.shopify_attributes
%}

{% schema %}
{
  "name": "Contact page",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Page heading", "default": "Contact us" },
    { "type": "text", "id": "intro_heading", "label": "Left column heading", "default": "Get in touch" },
    {
      "type": "textarea",
      "id": "intro_text",
      "label": "Left column text",
      "default": "Reach us anytime and we'll do our best to respond within one business day."
    },
    { "type": "header", "content": "Phone" },
    { "type": "text", "id": "phone_label", "label": "Label", "default": "Phone number" },
    { "type": "text", "id": "phone_value", "label": "Value", "default": "+91 XXXXX XXXXX" },
    { "type": "url", "id": "phone_url", "label": "Link" },
    { "type": "image_picker", "id": "phone_icon", "label": "Icon" },
    { "type": "header", "content": "Email" },
    { "type": "text", "id": "email_label", "label": "Label", "default": "Email" },
    { "type": "text", "id": "email_value", "label": "Value", "default": "askknatural01@gmail.com" },
    { "type": "url", "id": "email_url", "label": "Link" },
    { "type": "image_picker", "id": "email_icon", "label": "Icon" },
    { "type": "header", "content": "Instagram" },
    { "type": "text", "id": "instagram_label", "label": "Label", "default": "Instagram" },
    { "type": "text", "id": "instagram_value", "label": "Value", "default": "@askknatural" },
    { "type": "url", "id": "instagram_url", "label": "Link" },
    { "type": "image_picker", "id": "instagram_icon", "label": "Icon" },
    { "type": "header", "content": "Support hours" },
    { "type": "text", "id": "support_label", "label": "Label", "default": "Support hours" },
    {
      "type": "textarea",
      "id": "support_value",
      "label": "Value",
      "default": "Monday to Friday\n10:00 AM to 6:00 PM"
    },
    { "type": "url", "id": "support_url", "label": "Link (optional)" },
    { "type": "image_picker", "id": "support_icon", "label": "Icon" },
    { "type": "header", "content": "Form" },
    { "type": "text", "id": "form_heading", "label": "Form heading", "default": "Send us a message" },
    {
      "type": "textarea",
      "id": "form_text",
      "label": "Form intro",
      "default": "Tell us how we can help and our team will get back to you shortly."
    },
    { "type": "text", "id": "phone_default_country", "label": "Phone country code label", "default": "IN" }
  ],
  "blocks": [
    {
      "type": "contact_item",
      "name": "Contact item",
      "limit": 8,
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Email" },
        { "type": "text", "id": "value", "label": "Value", "default": "hello@example.com" },
        { "type": "url", "id": "url", "label": "Link (optional)" },
        { "type": "image_picker", "id": "icon", "label": "Icon image" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Contact page",
      "settings": {
        "phone_label": "Phone number",
        "phone_value": "+91 XXXXX XXXXX",
        "email_label": "Email",
        "email_value": "askknatural01@gmail.com",
        "instagram_label": "Instagram",
        "instagram_value": "@askknatural",
        "support_label": "Support hours",
        "support_value": "Monday to Friday\n10:00 AM to 6:00 PM"
      }
    }
  ]
}
{% endschema %}
