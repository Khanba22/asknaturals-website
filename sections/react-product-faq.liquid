{%- capture items_json -%}
[
{%- for block in section.blocks -%}
  {
    "question": {{ block.settings.question | json }},
    "answer": {{ block.settings.answer | json }}
  }{%- unless forloop.last -%},{%- endunless -%}
{%- endfor -%}
]
{%- endcapture -%}

{%- capture config_json -%}
{
  "heading": {{ section.settings.heading | json }},
  "subheading": {{ section.settings.subheading | json }},
  "items": {{ items_json }}
}
{%- endcapture -%}

{% render 'react-mount',
  mount_id: 'product-faq-' | append: section.id,
  component: 'ProductFaq',
  config_json: config_json,
  shopify_attributes: section.shopify_attributes
%}

{% schema %}
{
  "name": "Product FAQ",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "FAQ." },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Common Inquiries" }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ item",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "Who is this for?" },
        { "type": "textarea", "id": "answer", "label": "Answer", "default": "Designed for women seeking hormonal wellness support through Ayurvedic nutrition." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product FAQ",
      "blocks": [
        {
          "type": "faq",
          "settings": {
            "question": "Who is this for?",
            "answer": "Designed for women seeking hormonal wellness support through Ayurvedic nutrition."
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "When should I take it?",
            "answer": "Enjoy one serving daily, preferably in the morning or evening as part of your wellness routine."
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Is this a medicine?",
            "answer": "This is a dietary supplement, not a medicine. Consult your healthcare provider if you have specific conditions."
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "How long should I use it?",
            "answer": "Most customers notice benefits with consistent use over 8–12 weeks."
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Can I cancel subscription anytime?",
            "answer": "Yes — pause, skip, or cancel your subscription anytime from your account dashboard."
          }
        }
      ]
    }
  ]
}
{% endschema %}
