{%- capture config_json -%}
{
  "heading": {{ section.settings.heading | json }},
  "subheading": {{ section.settings.subheading | json }},
  "button_label": {{ section.settings.button_label | json }},
  "button_link": {{ section.settings.button_link | json }}
}
{%- endcapture -%}

{% render 'react-mount',
  mount_id: 'wellness-quiz-' | append: section.id,
  component: 'WellnessQuiz',
  config_json: config_json,
  shopify_attributes: section.shopify_attributes
%}

{% schema %}
{
  "name": "Wellness quiz CTA",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "NOT SURE WHAT YOUR BODY NEEDS RIGHT NOW?"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Answer a few thoughtful questions and receive personalized wellness recommendations designed around your goals, lifestyle, and how you feel day to day."
    },
    { "type": "text", "id": "button_label", "label": "Button", "default": "Take the wellness quiz" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "presets": [{ "name": "Wellness quiz CTA" }]
}
{% endschema %}
