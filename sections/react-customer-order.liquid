{%- unless customer -%}
  {% render 'customer-auth-redirect', return_to: request.path %}
{%- else -%}
  {%- capture order_json -%}
  {% render 'customer-order-detail-json' %}
  {%- endcapture -%}

  {%- capture config_json -%}
  {
    "order": {{ order_json }},
    "order_list_page_url": {{ routes.account_url | json }},
    "contact_page_url": {{ routes.contact_url | json }},
    "breadcrumbs": [
      { "title": "Home", "url": {{ routes.root_url | json }} },
      { "title": "Order history", "url": {{ routes.account_url | json }} },
      { "title": "Order summary", "url": {{ request.path | json }} }
    ]
  }
  {%- endcapture -%}

  {% render 'react-mount',
    mount_id: 'customer-order',
    component: 'OrderStatusPage',
    config_json: config_json,
    shopify_attributes: section.shopify_attributes
  %}
{%- endunless -%}

{% schema %}
{
  "name": "Order summary",
  "tag": "section",
  "class": "section",
  "enabled_on": {
    "templates": ["customers/order"]
  },
  "settings": [
    {
      "type": "paragraph",
      "content": "Custom order tracking UI. Requires Classic customer accounts. Logged-out visitors are sent to sign in."
    }
  ],
  "presets": [
    {
      "name": "Order summary"
    }
  ]
}
{% endschema %}
